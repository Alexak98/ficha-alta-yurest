    {
      "parameters": {
        "fromEmail": "soporte@yurest.com",
        "toEmail": "={{ $('Crear Solicitud').item.json.body.Email }}",
        "subject": "Solicitud de creación de ficha de alta - Yurest",
        "html": "=<!DOCTYPE html>\n<html lang=\"es\">\n<head>\n  <meta charset=\"UTF-8\">\n  <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n  <title>Ficha de Alta - Yurest</title>\n</head>\n<body style=\"margin:0;padding:0;background:#f8fafc;font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',Arial,sans-serif;-webkit-font-smoothing:antialiased;color:#1e293b;\">\n\n  <table width=\"100%\" cellpadding=\"0\" cellspacing=\"0\" border=\"0\" style=\"background:#f8fafc;padding:40px 16px;\">\n    <tr>\n      <td align=\"center\">\n        <table width=\"100%\" cellpadding=\"0\" cellspacing=\"0\" border=\"0\" style=\"max-width:580px;background:#ffffff;border-radius:16px;overflow:hidden;box-shadow:0 8px 32px rgba(15,23,42,0.08);\">\n\n          <!-- HEADER -->\n          <tr>\n            <td style=\"background:linear-gradient(135deg,#0c0c0c 0%,#1a0808 50%,#2a0c0c 100%);padding:36px 40px 32px;position:relative;\">\n              <table cellpadding=\"0\" cellspacing=\"0\" border=\"0\" style=\"margin-bottom:22px;\">\n                <tr>\n                  <td style=\"background:#ffffff;padding:8px 16px;border-radius:10px;\">\n                    <img src=\"https://www.yurest.com/wp-content/uploads/2022/10/logotipo-yurest-rojo.png\" alt=\"Yurest\" style=\"height:24px;display:block;\">\n                  </td>\n                </tr>\n              </table>\n              <p style=\"margin:0;font-size:22px;font-weight:800;color:#ffffff;line-height:1.3;letter-spacing:-0.01em;\">Completa tu ficha de alta</p>\n              <p style=\"margin:8px 0 0;font-size:14px;color:rgba(255,255,255,0.55);line-height:1.5;\">Rellena los datos de tu empresa para comenzar el proceso con Yurest</p>\n            </td>\n          </tr>\n\n          <!-- BODY -->\n          <tr>\n            <td style=\"padding:36px 40px 8px;\">\n              <p style=\"margin:0 0 20px;font-size:15px;color:#1e293b;line-height:1.6;\">\n                Hola <strong>{{ $('Crear Solicitud').item.json.body.Nombre }}</strong>,\n              </p>\n              <p style=\"margin:0 0 28px;font-size:15px;color:#334155;line-height:1.7;\">\n                Te enviamos este formulario para que puedas completar tu alta con Yurest. Por favor, rellénalo cuando puedas, solo te llevará unos minutos.\n              </p>\n\n              <!-- CTA -->\n              <table cellpadding=\"0\" cellspacing=\"0\" border=\"0\" style=\"margin:0 0 12px;\">\n                <tr>\n                  <td align=\"center\" style=\"background:#fc5858;border-radius:10px;box-shadow:0 6px 18px rgba(252,88,88,0.35);\">\n                    <a href=\"{{ $('Crear Solicitud').item.json.body.form_url }}\"\n                       style=\"display:inline-block;padding:14px 32px;font-size:15px;font-weight:700;color:#ffffff;text-decoration:none;letter-spacing:0.01em;\">\n                      Rellenar ficha de alta →\n                    </a>\n                  </td>\n                </tr>\n              </table>\n\n              <p style=\"margin:24px 0 6px;font-size:11px;color:#94a3b8;font-weight:700;letter-spacing:0.06em;text-transform:uppercase;\">Enlace alternativo</p>\n              <p style=\"margin:0 0 28px;font-size:12px;word-break:break-all;line-height:1.5;\">\n                <a href=\"{{ $('Crear Solicitud').item.json.body.form_url }}\" style=\"color:#fc5858;text-decoration:none;\">\n                  {{ $('Crear Solicitud').item.json.body.form_url }}\n                </a>\n              </p>\n            </td>\n          </tr>\n\n          <!-- DIVIDER + FIRMA -->\n          <tr>\n            <td style=\"padding:0 40px 32px;\">\n              <table width=\"100%\" cellpadding=\"0\" cellspacing=\"0\" border=\"0\" style=\"margin:0 0 22px;\">\n                <tr><td style=\"border-top:1.5px solid #f1f5f9;\"></td></tr>\n              </table>\n              <p style=\"margin:0;font-size:14px;color:#64748b;line-height:1.7;\">\n                Si tienes cualquier duda no dudes en contactarme.<br><br>\n                Un saludo,<br>\n                <strong style=\"color:#1e293b;\">{{ $('Crear Solicitud').item.json.body.Comercial }}</strong><br>\n                <span style=\"color:#94a3b8;font-size:13px;\">Equipo comercial · Yurest</span>\n              </p>\n            </td>\n          </tr>\n\n          <!-- FOOTER -->\n          <tr>\n            <td style=\"background:#f8fafc;border-top:1.5px solid #e2e8f0;padding:18px 40px;\">\n              <table width=\"100%\" cellpadding=\"0\" cellspacing=\"0\" border=\"0\">\n                <tr>\n                  <td style=\"font-size:11px;color:#94a3b8;line-height:1.5;\">© Yurest · Notificación automática</td>\n                  <td align=\"right\" style=\"font-size:11px;\"><a href=\"https://yurest.com\" style=\"color:#fc5858;text-decoration:none;font-weight:700;\">yurest.com</a></td>\n                </tr>\n              </table>\n            </td>\n          </tr>\n\n        </table>\n      </td>\n    </tr>\n  </table>\n\n</body>\n</html>\n",
        "options": {}
      },
