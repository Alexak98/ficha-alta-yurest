      "alwaysOutputData": true
    },
    {
      "parameters": {
        "jsCode": "const items = $input.all().filter(i => i.json && i.json.id);\n\n// Reconstruir formato que el frontend espera\n// Filtrar solicitudes ya completadas (el cliente ya rellenó la ficha)\nconst solicitudes = items\n  .filter(item => {\n    const s = item.json;\n    const estado = (s.estado || '').toLowerCase();\n    return estado !== 'completado';\n  })\n  .map(item => {\n    const s = item.json;\n    const datos = typeof s.datos === 'string' ? JSON.parse(s.datos || '{}') : (s.datos || {});\n    // Merge: datos guardados + campos directos\n    // s.estado tiene prioridad sobre datos['Estado'] (el campo directo se actualiza al completar)\n    return {\n      ...datos,\n      id: s.id,\n      'ID Solicitud': datos['ID Solicitud'] || s.id,\n      'Nombre Sociedad': datos['Nombre Sociedad'] || '',\n      'Nombre': datos['Nombre'] || '',\n      'Email': datos['Email'] || '',\n      'Comercial': datos['Comercial'] || '',\n      'Tipo Cliente': datos['Tipo Cliente'] || s.tipo || '',\n      'Estado': s.estado || datos['Estado'] || 'Pendiente',\n      'Fecha': datos['Fecha'] || s.created_at || '',\n      'Fecha Solicitud': datos['Fecha'] || s.created_at || ''\n    };\n  });\nreturn [{ json: { solicitudes } }];"
      },
      "id": "format-get-sol",
      "name": "Formatear GET",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        700,
        200
      ],
      "alwaysOutputData": true
    },
