    {
      "parameters": {
        "jsCode": "const { solicitudId, accessToken, clienteData } = $('Guardar Body').first().json;\nconst allSol = $input.all().map(i => i.json).filter(s => s.id);\n\nlet solicitudUUID = null;\nlet comercial = '';\nlet tipo = '';\n\n// Primero por access_token (URL pública nueva), luego por ID-Solicitud (legacy).\nfor (const sol of allSol) {\n  let datos = sol.datos;\n  if (typeof datos === 'string') {\n    try { datos = JSON.parse(datos); } catch(_) { datos = {}; }\n  }\n  const solId = datos['ID Solicitud'] || '';\n  const matchToken = accessToken && sol.access_token === accessToken;\n  const matchId    = !accessToken && solicitudId && String(solId) === String(solicitudId);\n  if (matchToken || matchId) {\n    solicitudUUID = sol.id;\n    comercial = datos['Comercial'] || '';\n    tipo = datos['Tipo Cliente'] || sol.tipo || '';\n    break;\n  }\n}\n\nconst ficha = {\n  comercial: comercial,\n  denominacion: clienteData['Nombre Sociedad'] || '',\n  nombre_comercial: clienteData['Nombre Comercial'] || '',\n  calle: clienteData['Calle'] || '',\n  numero: clienteData['Número'] || '',\n  cp: clienteData['CP'] || '',\n  municipio: clienteData['Municipio'] || '',\n  provincia: clienteData['Provincia'] || '',\n  cif: clienteData['CIF/NIF'] || '',\n  email: clienteData['Email'] || '',\n  email_factura: clienteData['Email Factura'] || '',\n  email_cc: clienteData['Email CC'] || '',\n  tipo_cliente: tipo,\n  jp_nombre: clienteData['JP Nombre'] || '',\n  jp_apellidos: clienteData['JP Apellidos'] || '',\n  jp_rol: clienteData['JP Rol'] || '',\n  jp_telefono: clienteData['JP Teléfono'] || '',\n  jp_mail: clienteData['JP Mail'] || '',\n  firm_nombre: clienteData['Firmante Nombre'] || '',\n  firm_apellidos: clienteData['Firmante Apellidos'] || '',\n  firm_mail: clienteData['Firmante Mail'] || '',\n  firm_dni: clienteData['Firmante DNI'] || '',\n  firm_puesto: clienteData['Firmante Puesto'] || '',\n  tpv: clienteData['TPV'] || '',\n  tpv_contacto: clienteData['TPV Contacto'] || '',\n  tpv_email: clienteData['TPV Email'] || '',\n  estado: 'completada',\n  baja: 'No'\n};\n\nif (clienteData['SEPA'] && typeof clienteData['SEPA'] === 'object') {\n  // NO stringify. La columna es JSONB y el nodo Supabase ya serializa.\n  // Si hacemos JSON.stringify aquí, Postgres guarda un valor escalar\n  // (string JSON) en vez de un objeto, y falla al hacer sepa_mandato-\\u003E\\u003E'referencia' o jsonb_set() con \\\"cannot set path in scalar\\\".\n  ficha.sepa_mandato = clienteData['SEPA'];\n}\n\nreturn [{ json: { ficha, solicitudUUID, solicitudId, comercial, tipo } }];"
      },
