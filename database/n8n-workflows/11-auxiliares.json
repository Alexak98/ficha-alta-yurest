    {
      "parameters": {
        "jsCode": "const { solicitudId, clienteData } = $('Guardar Body').first().json;\nconst allSol = $input.all().map(i => i.json).filter(s => s.id);\n\nlet solicitudUUID = null;\nlet comercial = '';\nlet tipo = '';\n\nfor (const sol of allSol) {\n  let datos = sol.datos;\n  if (typeof datos === 'string') {\n    try { datos = JSON.parse(datos); } catch(_) { datos = {}; }\n  }\n  const solId = datos['ID Solicitud'] || '';\n  if (String(solId) === String(solicitudId)) {\n    solicitudUUID = sol.id;\n    comercial = datos['Comercial'] || '';\n    tipo = datos['Tipo Cliente'] || sol.tipo || '';\n    break;\n  }\n}\n\nconst ficha = {\n  comercial: comercial,\n  denominacion: clienteData['Nombre Sociedad'] || '',\n  nombre_comercial: clienteData['Nombre Comercial'] || '',\n  calle: clienteData['Calle'] || '',\n  numero: clienteData['Número'] || '',\n  cp: clienteData['CP'] || '',\n  municipio: clienteData['Municipio'] || '',\n  provincia: clienteData['Provincia'] || '',\n  cif: clienteData['CIF/NIF'] || '',\n  email: clienteData['Email'] || '',\n  email_factura: clienteData['Email Factura'] || '',\n  email_cc: clienteData['Email CC'] || '',\n  tipo_cliente: tipo,\n  jp_nombre: clienteData['JP Nombre'] || '',\n  jp_apellidos: clienteData['JP Apellidos'] || '',\n  jp_rol: clienteData['JP Rol'] || '',\n  jp_telefono: clienteData['JP Teléfono'] || '',\n  jp_mail: clienteData['JP Mail'] || '',\n  firm_nombre: clienteData['Firmante Nombre'] || '',\n  firm_apellidos: clienteData['Firmante Apellidos'] || '',\n  firm_mail: clienteData['Firmante Mail'] || '',\n  firm_dni: clienteData['Firmante DNI'] || '',\n  firm_puesto: clienteData['Firmante Puesto'] || '',\n  tpv: clienteData['TPV'] || '',\n  tpv_contacto: clienteData['TPV Contacto'] || '',\n  tpv_email: clienteData['TPV Email'] || '',\n  estado: 'completada',\n  baja: 'No'\n};\n\nreturn [{ json: { ficha, solicitudUUID, solicitudId, comercial, tipo } }];"
      },
