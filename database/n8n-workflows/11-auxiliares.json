    {
      "parameters": {
        "jsCode": "// Mapear comercial → email de destino\nconst { comercial, ficha } = $('Merge Solicitud + Cliente').first().json;\n\nconst emailMap = {\n  'Santiago Gonzalez': 'a.abramyan@yurest.com',\n  'Borja Pastor': 'b.pastor@yurest.com',\n  'Ivan Ramirez': 'i.ramirez@yurest.com',\n  'Pedro Martin': 'p.martin@yurest.com',\n  'Ismael Calero': 'i.calero@yurest.com',\n  'Springboard Monica': 'm.springboard@yurest.com',\n  'Springboard Pau': 'p.springboard@yurest.com'\n};\n\nconst toEmail = emailMap[comercial] || 'soporte@yurest.com';\nconst nombreComercial = ficha.nombre_comercial || ficha.denominacion || 'Cliente';\n\nreturn [{ json: {\n  toEmail,\n  comercial,\n  nombreComercial\n} }];"
      },
      "id": "map-comercial-email",
      "name": "Map Comercial Email",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
