    {
      "parameters": {
        "jsCode": "// Guardar solo el ID de la carpeta Drive (no la URL completa).\n// El frontend construirá la URL como https://drive.google.com/drive/u/1/folders/{id}\nconst fichaId = $('INSERT Ficha Alta').first().json.id;\nconst driveResult = $input.first().json;\n\n// El ID puede venir en diferentes campos según la respuesta del nodo Google Drive\nconst driveId = driveResult.id\n             || driveResult.fileId\n             || driveResult.folderId\n             || '';\n\nif (!driveId) {\n  throw new Error('No se pudo obtener el ID de la carpeta Drive. Campos disponibles: ' + Object.keys(driveResult).join(', '));\n}\n\nreturn [{ json: { id: fichaId, carpeta_drive: driveId } }];"
      },
