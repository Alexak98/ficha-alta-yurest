    {
      "parameters": {
        "jsCode": "// Si el cliente marcó \"TPV no integrado\", emitimos un item con los datos\n// para crear una tarea en Asana + avisar por email a integraciones.\n// Si no, devolvemos [] para que la rama no continúe.\n//\n// Importante: el cliente NO envía el campo \"Comercial\" en el formulario de\n// solicitud (no lo conoce). El comercial se asignó cuando el comercial creó\n// la solicitud y vive en solicitudes.datos['Comercial'], que el nodo\n// 'Merge Solicitud + Cliente' ya nos expone como `comercial`.\nconst body = $('Guardar Body').first().json;\nconst c = body.clienteData || body.body || body;\nconst noInt = c['TPV No Integrado'] === 'Sí' || c.tpv_no_integrado === true || c.tpv_no_integrado === 'true';\nif (!noInt) return [];\nconst merge = $('Merge Solicitud + Cliente').first().json || {};\nconst tpvNombre   = (c['TPV NI Nombre']   || '').trim() || 'TPV sin nombre';\nconst tpvPersona  = (c['TPV NI Contacto'] || '').trim();\nconst tpvEmail    = (c['TPV NI Email']    || '').trim();\nconst nombreCom   = (c['Nombre Comercial']|| c['Nombre Sociedad'] || '').trim() || 'Cliente sin nombre';\nconst comercial   = (merge.comercial || c['Comercial'] || '').trim() || '—';\nconst sociedad    = (c['Nombre Sociedad'] || '').trim();\nreturn [{ json: { tpvNombre, tpvPersona, tpvEmail, nombreCom, comercial, sociedad } }];"
      },
