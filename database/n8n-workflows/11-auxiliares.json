    {
      "parameters": {
        "jsCode": "// Mapear comercial → email de destino\nconst { comercial, ficha } = $('Merge Solicitud + Cliente').first().json;\n\nconst emailMap = {\n  'Santiago Gonzalez': 'a.abramyan@yurest.com',\n  'Borja Pastor': 'b.pastor@yurest.com',\n  'Ivan Ramirez': 'i.ramirez@yurest.com',\n  'Pedro Martin': 'p.martin@yurest.com',\n  'Ismael Calero': 'i.calero@yurest.com',\n  'Springboard Monica': 'm.springboard@yurest.com',\n  'Springboard Pau': 'p.springboard@yurest.com'\n};\n\nconst toEmail = emailMap[comercial] || 'soporte@yurest.com';\nconst nombreComercial = ficha.nombre_comercial || ficha.denominacion || 'Cliente';\n\nreturn [{ json: {\n  toEmail,\n  comercial,\n  nombreComercial\n} }];"
      },
      "id": "map-comercial-email",
      "name": "Map Comercial Email",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1040,
        740
      ],
      "alwaysOutputData": true
    },
    {
      "parameters": {
        "fromEmail": "soporte@yurest.com",
        "toEmail": "={{ $json.toEmail }}",
        "subject": "={{ $json.nombreComercial }} ha rellenado la ficha",
        "html": "=<!DOCTYPE html>\n<html lang=\"es\">\n<head>\n  <meta charset=\"UTF-8\">\n  <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n  <title>Notificación de Alta de Cliente</title>\n</head>\n<body style=\"margin:0;padding:0;background:#f1f5f9;font-family:'Segoe UI',Arial,sans-serif;\">\n\n  <table width=\"100%\" cellpadding=\"0\" cellspacing=\"0\" style=\"background:#f1f5f9;padding:40px 0;\">\n    <tr>\n      <td align=\"center\">\n        <table width=\"600\" cellpadding=\"0\" cellspacing=\"0\" style=\"max-width:600px;width:100%;\">\n\n          <tr>\n            <td style=\"background:#fc5858;border-radius:16px 16px 0 0;padding:36px 40px;text-align:center;\">\n              <p style=\"margin:0 0 6px;font-size:0.7rem;font-weight:800;letter-spacing:0.2em;text-transform:uppercase;color:rgba(255,255,255,0.7);\">● YUREST · GESTIÓN</p>\n              <h1 style=\"margin:0;color:#ffffff;font-size:1.75rem;font-weight:800;line-height:1.2;\">Ficha de alta completada</h1>\n              <p style=\"margin:12px 0 0;color:rgba(255,255,255,0.88);font-size:0.95rem;\">Un nuevo cliente ha finalizado su registro correctamente.</p>\n            </td>\n          </tr>\n\n          <tr>\n            <td style=\"background:#ffffff;padding:40px 40px 32px;\">\n\n              <p style=\"margin:0 0 20px;font-size:1rem;color:#1e293b;line-height:1.6;\">Hola {{ $json.comercial }},</p>\n\n              <p style=\"margin:0 0 24px;font-size:1rem;color:#475569;line-height:1.6;\">\n                Te informamos que el cliente <strong style=\"color:#1e293b;\">{{ $json.nombreComercial }}</strong> ha completado satisfactoriamente su ficha de alta y los datos ya están disponibles en el sistema.\n              </p>\n\n              <table width=\"100%\" cellpadding=\"0\" cellspacing=\"0\" style=\"background:#fef9c3;border-left:4px solid #eab308;border-radius:4px;margin-bottom:28px;\">\n                <tr>\n                  <td style=\"padding:16px 20px;\">\n                    <p style=\"margin:0;font-size:0.9rem;color:#854d0e;font-weight:600;line-height:1.4;\">\n                      <strong>Estado:</strong> Pendiente de revisión y finalización por tu parte.\n                    </p>\n                  </td>\n                </tr>\n              </table>\n\n              <p style=\"margin:0 0 28px;font-size:0.95rem;color:#475569;line-height:1.6;\">\n                Por favor, accede al panel administrativo para verificar la información y completar el proceso oficial de registro:\n              </p>\n\n              <table width=\"100%\" cellpadding=\"0\" cellspacing=\"0\">\n                <tr>\n                  <td align=\"center\" style=\"padding-bottom:12px;\">\n                    <a href=\"https://panel.yurest.com\" target=\"_blank\"\n                       style=\"display:inline-block;background:#1e293b;color:#ffffff;text-decoration:none;font-size:0.92rem;font-weight:700;padding:14px 32px;border-radius:10px;\">\n                      Ver panel de administración →\n                    </a>\n                  </td>\n                </tr>\n              </table>\n\n            </td>\n          </tr>\n\n          <tr>\n            <td style=\"background:#f8fafc;border-radius:0 0 16px 16px;border-top:1.5px solid #e2e8f0;padding:24px 40px;text-align:center;\">\n              <p style=\"margin:0 0 4px;font-size:0.78rem;font-weight:800;letter-spacing:0.15em;text-transform:uppercase;color:#fc5858;\">● YUREST</p>\n              <p style=\"margin:0;font-size:0.75rem;color:#94a3b8;\">Notificación automática · Sistema de Altas</p>\n            </td>\n          </tr>\n\n        </table>\n      </td>\n    </tr>\n  </table>\n\n</body>\n</html>",
        "options": {}
      },
