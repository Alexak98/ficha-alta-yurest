      "parameters": {
        "jsCode": "const { row } = $input.first().json;\ndelete row._accion;\ndelete row._cliente_id;\ndelete row._fecha_baja_original;\ndelete row.id; // INSERT: dejar que Supabase genere el UUID\nreturn [{ json: row }];"
      },
