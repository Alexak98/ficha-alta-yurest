{
  "name": "Yurest - Eliminar Ficha o Solicitud (seguro)",
  "nodes": [
    {
      "parameters": {
        "httpMethod": "POST",
        "path": "a2b1b1d6-a1dc-4366-b60e-b5e4506faa3d",
        "responseMode": "responseNode",
        "options": {}
      },
      "id": "wh-del",
      "name": "Webhook DELETE",
      "type": "n8n-nodes-base.webhook",
      "typeVersion": 2,
      "position": [
        240,
        300
      ],
      "webhookId": "eliminar"
    },
    {
      "parameters": {
        "jsCode": "// Normaliza el payload. 'entity' ya no se usa para decidir rama porque\n// los IDs son UUIDs únicos entre fichas_alta y solicitudes: hacemos el\n// soft-delete en AMBAS tablas y solo la que tenga el UUID se actualiza.\n// Así eliminamos la dependencia de un IF node que no estaba enrutando\n// correctamente en n8n v2 y llevaba el request al branch equivocado.\nconst raw = $input.first().json;\nconst query = raw.query || {};\nconst body = raw.body || {};\n\nconst id = query.id || body.row_number || body.id || body.ID || '';\nif (!id) throw new Error('Falta ID para eliminar');\n\nconst entity = (query.entity || body.entity || '').toLowerCase();\n// 'entity' se acepta pero es informativo (devuelto en la respuesta).\n// Sin validación estricta: si viene algo raro, seguimos adelante.\n\nreturn [{ json: { id, entity: entity || 'desconocido' } }];"
      },
      "id": "prepare-del",
      "name": "Preparar DELETE",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        480,
        300
      ],
      "alwaysOutputData": true
    },
    {
      "parameters": {
        "operation": "update",
        "tableId": "fichas_alta",
        "filterType": "manual",
        "matchType": "allFilters",
        "filters": {
          "conditions": [
            {
              "keyName": "id",
              "condition": "eq",
              "keyValue": "={{ $json.id }}"
            }
          ]
        },
        "fieldsUi": {
          "fieldValues": [
            {
              "fieldId": "deleted_at",
              "fieldValue": "={{ $now.toISOString() }}"
            }
          ]
        },
        "options": {},
        "alwaysOutputData": true
      },
      "id": "supa-del-ficha",
      "name": "Soft-delete Ficha",
      "type": "n8n-nodes-base.supabase",
      "typeVersion": 1,
      "position": [
        700,
        300
      ],
      "credentials": {
        "supabaseApi": {
          "id": "SUPABASE_CREDENTIAL_ID",
          "name": "Supabase Yurest"
        }
      },
      "alwaysOutputData": true
    },
    {
      "parameters": {
        "jsCode": "// Recupera id/entity del paso Preparar DELETE (el Supabase update\n// anterior reemplaza $json con la fila actualizada o un objeto vacío).\nconst prep = $('Preparar DELETE').first().json;\nreturn [{ json: { id: prep.id, entity: prep.entity } }];"
      },
      "id": "restore-ctx-1",
      "name": "Recuperar contexto",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        920,
        300
      ],
      "alwaysOutputData": true
    },
    {
      "parameters": {
        "operation": "update",
        "tableId": "solicitudes",
        "filterType": "manual",
        "matchType": "allFilters",
        "filters": {
          "conditions": [
            {
              "keyName": "id",
              "condition": "eq",
              "keyValue": "={{ $json.id }}"
            }
          ]
        },
        "fieldsUi": {
          "fieldValues": [
            {
              "fieldId": "deleted_at",
              "fieldValue": "={{ $now.toISOString() }}"
            }
          ]
        },
        "options": {},
        "alwaysOutputData": true
      },
      "id": "supa-del-sol",
      "name": "Soft-delete Solicitud",
      "type": "n8n-nodes-base.supabase",
      "typeVersion": 1,
      "position": [
        1140,
        300
      ],
      "credentials": {
        "supabaseApi": {
          "id": "SUPABASE_CREDENTIAL_ID",
          "name": "Supabase Yurest"
        }
      },
      "alwaysOutputData": true
    },
    {
      "parameters": {
        "respondWith": "json",
        "responseBody": "={{ JSON.stringify({ success: true, entity: $('Preparar DELETE').first().json.entity, id: $('Preparar DELETE').first().json.id }) }}",
        "options": {
          "responseHeaders": {
            "entries": [
              {
                "name": "Access-Control-Allow-Origin",
                "value": "*"
              },
              {
                "name": "Access-Control-Allow-Methods",
                "value": "GET, POST, PUT, DELETE, OPTIONS"
              },
              {
                "name": "Access-Control-Allow-Headers",
                "value": "Content-Type, Authorization"
              },
              {
                "name": "Content-Type",
                "value": "application/json"
              }
            ]
          }
        }
      },
      "id": "respond-ok",
      "name": "Respond OK",
      "type": "n8n-nodes-base.respondToWebhook",
      "typeVersion": 1.1,
      "position": [
        1360,
        300
      ]
    }
  ],
  "connections": {
    "Webhook DELETE": {
      "main": [
