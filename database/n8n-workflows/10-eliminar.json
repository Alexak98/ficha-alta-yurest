{
  "name": "Yurest - Eliminar Ficha o Solicitud (seguro)",
  "nodes": [
    {
      "parameters": {
        "httpMethod": "POST",
        "path": "a2b1b1d6-a1dc-4366-b60e-b5e4506faa3d",
        "responseMode": "responseNode",
        "options": {}
      },
      "id": "wh-del",
      "name": "Webhook DELETE",
      "type": "n8n-nodes-base.webhook",
      "typeVersion": 2,
      "position": [240, 300],
      "webhookId": "eliminar"
    },
    {
      "parameters": {
        "jsCode": "// Extrae id/entity del request. UUIDs son únicos entre fichas_alta y\n// solicitudes; intentamos soft-delete en ambas tablas y devolvemos cuántas\n// filas afectó cada UPDATE.\nconst raw = $input.first().json;\nconst query = raw.query || {};\nconst body = raw.body || {};\nconst id = query.id || body.row_number || body.id || body.ID || '';\nif (!id) throw new Error('Falta ID para eliminar');\nconst entity = (query.entity || body.entity || '').toLowerCase() || 'desconocido';\nreturn [{ json: { id, entity } }];"
      },
      "id": "prepare-del",
      "name": "Preparar DELETE",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [460, 300],
      "alwaysOutputData": true
    },
    {
      "parameters": {
        "operation": "update",
        "tableId": "fichas_alta",
        "filterType": "manual",
        "matchType": "allFilters",
        "filters": {
          "conditions": [
            {
              "keyName": "id",
              "condition": "eq",
              "keyValue": "={{ $json.id }}"
            }
          ]
        },
        "fieldsUi": {
          "fieldValues": [
            {
              "fieldId": "deleted_at",
              "fieldValue": "={{ $now.toISO() }}"
            }
          ]
        },
        "options": {}
      },
      "id": "supa-del-ficha",
      "name": "Soft-delete Ficha",
      "type": "n8n-nodes-base.supabase",
      "typeVersion": 1,
      "position": [680, 300],
      "credentials": {
        "supabaseApi": {
          "id": "SUPABASE_CREDENTIAL_ID",
          "name": "Supabase Yurest"
        }
      },
      "alwaysOutputData": true,
      "continueOnFail": true
    },
    {
      "parameters": {
        "operation": "update",
        "tableId": "solicitudes",
        "filterType": "manual",
        "matchType": "allFilters",
        "filters": {
          "conditions": [
            {
              "keyName": "id",
              "condition": "eq",
              "keyValue": "={{ $('Preparar DELETE').first().json.id }}"
            }
          ]
        },
        "fieldsUi": {
          "fieldValues": [
            {
              "fieldId": "deleted_at",
              "fieldValue": "={{ $now.toISO() }}"
            }
          ]
        },
        "options": {}
      },
      "id": "supa-del-sol",
      "name": "Soft-delete Solicitud",
      "type": "n8n-nodes-base.supabase",
      "typeVersion": 1,
      "position": [900, 300],
      "credentials": {
        "supabaseApi": {
          "id": "SUPABASE_CREDENTIAL_ID",
          "name": "Supabase Yurest"
        }
      },
      "alwaysOutputData": true,
      "continueOnFail": true
    },
    {
      "parameters": {
        "jsCode": "// Cuenta filas afectadas leyendo los outputs de los dos UPDATE Supabase.\n// El nodo Supabase v1 devuelve directamente la fila actualizada (con `id`)\n// o un objeto { error: { message } } si fallò (gracias a continueOnFail).\nconst { id, entity } = $('Preparar DELETE').first().json;\n\nfunction inspeccionar(items) {\n  let count = 0;\n  const errores = [];\n  for (const it of (items || [])) {\n    const j = (it && it.json) ? it.json : it;\n    if (!j) continue;\n    if (j.error) {\n      const msg = j.error.message || j.error.code || JSON.stringify(j.error);\n      errores.push(String(msg));\n      continue;\n    }\n    if (j.id) { count++; continue; }\n    if (Array.isArray(j.data)) count += j.data.length;\n  }\n  return { count, errores };\n}\n\nconst f = inspeccionar($('Soft-delete Ficha').all());\nconst s = inspeccionar($('Soft-delete Solicitud').all());\n\nreturn [{ json: {\n  success: (f.count + s.count) > 0,\n  entity: entity,\n  id: id,\n  ficha_count: f.count,\n  sol_count: s.count,\n  errores: [...f.errores, ...s.errores]\n} }];"
      },
      "id": "verify-counts",
      "name": "Verificar afectados",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [1120, 300],
      "alwaysOutputData": true,
      "executeOnce": true
    },
    {
      "parameters": {
        "respondWith": "json",
        "responseBody": "={{ JSON.stringify($json) }}",
        "options": {
          "responseHeaders": {
            "entries": [
              { "name": "Access-Control-Allow-Origin",  "value": "*" },
              { "name": "Access-Control-Allow-Methods", "value": "GET, POST, PUT, DELETE, OPTIONS" },
              { "name": "Access-Control-Allow-Headers", "value": "Content-Type, Authorization" },
              { "name": "Content-Type",                 "value": "application/json" }
            ]
          }
        }
      },
      "id": "respond-ok",
      "name": "Respond OK",
      "type": "n8n-nodes-base.respondToWebhook",
      "typeVersion": 1.1,
      "position": [1340, 300]
    }
  ],
  "connections": {
    "Webhook DELETE": {
      "main": [[{ "node": "Preparar DELETE", "type": "main", "index": 0 }]]
    },
    "Preparar DELETE": {
      "main": [[{ "node": "Soft-delete Ficha", "type": "main", "index": 0 }]]
    },
    "Soft-delete Ficha": {
      "main": [[{ "node": "Soft-delete Solicitud", "type": "main", "index": 0 }]]
    },
    "Soft-delete Solicitud": {
      "main": [[{ "node": "Verificar afectados", "type": "main", "index": 0 }]]
    },
    "Verificar afectados": {
      "main": [[{ "node": "Respond OK", "type": "main", "index": 0 }]]
    }
  },
  "settings": {
    "executionOrder": "v1"
  },
  "tags": [
    { "name": "yurest" },
    { "name": "eliminar" }
  ]
}
