        "filterType": "manual",
        "matchType": "allFilters",
        "filters": {
          "conditions": [
            {
              "keyName": "id",
              "condition": "eq",
              "keyValue": "={{ $json.id }}"
            }
          ]
        },
        "dataToSend": "autoMapInputData",
        "options": {}
      },
      "id": "supa-update-promo",
      "name": "UPDATE Promoción",
      "type": "n8n-nodes-base.supabase",
      "typeVersion": 1,
      "position": [
        1240,
        620
      ],
      "credentials": {
        "supabaseApi": {
          "id": "SUPABASE_CREDENTIAL_ID",
          "name": "Supabase Yurest"
        }
      },
      "alwaysOutputData": true
    },
    {
      "parameters": {
        "jsCode": "// Respuesta unificada — devuelve el registro persistido + action.\nconst rows = ($input.all() || []).map(i => i.json).filter(x => x && x.id);\nreturn [{ json: { success: rows.length > 0, promocion: rows[0] || null, errores: [] } }];"
      },
      "id": "format-promo-result",
      "name": "Formatear resultado",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1440,
        560
      ]
    },
    {
      "parameters": {
        "jsCode": "// Pass-through: Preparar Promoción ya emitió el item con forma de\n// respuesta {__done, success, errores, action}.\nreturn [$input.first()];"
      },
      "id": "format-promo-error",
