    {
      "parameters": {
        "jsCode": "// La rama de UPDATE/DELETE/REACTIVAR aplana el payload: pasa row tal cual\n// al nodo Supabase que usa autoMapInputData.\nreturn [{ json: $json.row }];"
      },
      "id": "flatten-promo-update",
      "name": "Aplanar UPDATE",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1040,
        620
      ]
    },
    {
