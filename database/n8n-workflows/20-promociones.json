      ]
    },
    {
      "parameters": {
        "jsCode": "// Aplana igual que Aplanar UPDATE: el nodo Supabase INSERT usa\n// autoMapInputData y necesita el row como raíz, no {action,row,errores}.\nreturn [{ json: $json.row }];"
      },
      "id": "aplanar-insert-promo",
      "name": "Aplanar INSERT",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
