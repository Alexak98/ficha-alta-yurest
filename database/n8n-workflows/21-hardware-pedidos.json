      "continueOnFail": true
    },
    {
      "parameters": {
        "jsCode": "const row = $json.row || {};\nconst id = row.id;\nconst body = { ...row };\ndelete body.id;\nreturn [{ json: { id, __body: JSON.stringify(body) } }];"
      },
