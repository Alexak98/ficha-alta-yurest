    {
      "parameters": {
        "jsCode": "const d = $input.first().json.body;\n\n// Actualizar el campo implementador en fichas_alta\nconst fichaId = d.id || d.ficha_id || '';\nconst implementador = d.implementador || d.Implementador || '';\n\nif (!fichaId) {\n  throw new Error('Falta el ID de la ficha');\n}\n\nreturn [{ json: { \n  fichaId,\n  implementador,\n  datos: d\n} }];"
      },
      "id": "prepare-dist",
      "name": "Preparar Distribución",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        480,
        300
      ]
    },
    {
      "parameters": {
        "jsCode": "// Actualizar implementador en fichas_alta\nconst { fichaId, implementador } = $input.first().json;\nreturn [{ json: { id: fichaId, implementador } }];"
      },
      "id": "map-update-ficha",
      "name": "Map Update Ficha",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
