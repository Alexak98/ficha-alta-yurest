      "typeVersion": 1,
      "position": [
        920,
        300
      ],
      "credentials": {
        "supabaseApi": {
          "id": "SUPABASE_CREDENTIAL_ID",
          "name": "Supabase Yurest"
        }
      }
    },
    {
      "parameters": {
        "jsCode": "// También registrar en tabla distribucion\nconst orig = $('Preparar Distribución').first().json;\nreturn [{ json: {\n  implementador: orig.implementador,\n  ficha_id: orig.fichaId,\n  datos: JSON.stringify(orig.datos)\n} }];"
      },
