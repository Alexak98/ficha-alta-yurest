      "id": "if-enviar-integ",
      "name": "¿Enviar Integraciones?",
      "type": "n8n-nodes-base.if",
      "typeVersion": 2,
      "position": [
        860,
        400
      ]
    },
    {
      "parameters": {
        "jsCode": "// Construye el item que consumen Crear tarea Asana + Email integraciones.\n// Mantiene los mismos nombres de campos que usaba el workflow 11 para que\n// los bodies de Asana y la plantilla HTML del email sigan funcionando\n// sin cambios en sus expresiones.\nconst c = $('Cargar Ficha').first().json;\nreturn [{ json: {\n  tpvNombre:  (c.tpv_ni_nombre   || '').trim() || 'TPV sin nombre',\n  tpvPersona: (c.tpv_ni_contacto || '').trim(),\n  tpvEmail:   (c.tpv_ni_email    || '').trim(),\n  nombreCom:  (c.nombre_comercial || c.denominacion || '').trim() || 'Cliente sin nombre',\n  comercial:  (c.comercial       || '').trim() || '—',\n  sociedad:   (c.denominacion    || '').trim()\n}}];"
      },
      "id": "prep-notif-tpv",
      "name": "Preparar Notif TPV NI",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1060,
        400
      ],
      "alwaysOutputData": true
    },
    {
      "parameters": {
        "method": "POST",
        "url": "https://app.asana.com/api/1.0/tasks",
        "authentication": "predefinedCredentialType",
        "nodeCredentialType": "asanaApi",
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\n  \"data\": {\n    \"name\": {{ JSON.stringify($json.tpvNombre + ' - ' + $json.nombreCom) }},\n    \"notes\": {{ JSON.stringify('Persona de referencia: ' + ($json.tpvPersona || '—') + '\\nEmail de referencia: ' + ($json.tpvEmail || '—') + '\\nCliente: ' + $json.nombreCom + '\\nComercial: ' + $json.comercial) }},\n    \"projects\": [\"1207920061546505\"]\n  }\n}",
        "options": {}
      },
      "id": "asana-completa",
      "name": "Crear tarea Asana TPV NI",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        1260,
        400
      ],
      "credentials": {
        "asanaApi": {
          "id": "ASANA_CREDENTIAL_ID",
          "name": "Asana Yurest"
        }
      }
    },
    {
      "parameters": {
        "fromEmail": "soporte@yurest.com",
        "toEmail": "soporte@yurest.com,a.jareno@yurest.com,luis@roocket.io",
        "subject": "=Nueva integracion TPV - {{ $('Preparar Notif TPV NI').first().json.tpvNombre }}",
        "html": "=<!DOCTYPE html>\n<html lang=\"es\">\n<body style=\"margin:0;padding:0;background:#f1f1f1;font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',sans-serif;\">\n<table width=\"100%\" cellpadding=\"0\" cellspacing=\"0\" border=\"0\" style=\"background:#f1f1f1;padding:32px 16px;\">\n  <tr><td align=\"center\">\n    <table width=\"100%\" cellpadding=\"0\" cellspacing=\"0\" border=\"0\" style=\"max-width:560px;\">\n      <tr><td style=\"background:linear-gradient(135deg,#111111,#2d0c0c);border-radius:14px 14px 0 0;padding:28px 32px;\">\n        <p style=\"margin:0;font-size:11px;font-weight:700;letter-spacing:.14em;text-transform:uppercase;color:#fca5a5;\">Yurest · Integraciones</p>\n        <p style=\"margin:8px 0 0;font-size:20px;font-weight:700;color:#ffffff;\">Nueva integración TPV pendiente</p>\n      </td></tr>\n      <tr><td style=\"background:#ffffff;padding:28px 32px;\">\n        <p style=\"margin:0 0 16px;font-size:14px;color:#334155;line-height:1.6;\">\n          Se ha añadido un cliente con una integración TPV <strong>no realizada</strong>. Se ha creado la tarea correspondiente en el proyecto <strong>Integraciones</strong> de Asana.\n        </p>\n        <table width=\"100%\" cellpadding=\"0\" cellspacing=\"0\" border=\"0\" style=\"border:1.5px solid #f1f5f9;border-radius:10px;margin:0 0 18px;\">\n          <tr><td style=\"background:#f8fafc;padding:10px 16px;border-bottom:1px solid #f1f5f9;font-size:11px;font-weight:700;letter-spacing:.1em;text-transform:uppercase;color:#fc5858;\">Datos de referencia</td></tr>\n          <tr><td style=\"padding:14px 16px;font-size:13px;color:#1e293b;line-height:1.7;\">\n            <strong>TPV:</strong> {{ $('Preparar Notif TPV NI').first().json.tpvNombre }}<br>\n            <strong>Cliente (nombre comercial):</strong> {{ $('Preparar Notif TPV NI').first().json.nombreCom }}<br>\n            <strong>Comercial responsable:</strong> {{ $('Preparar Notif TPV NI').first().json.comercial }}<br>\n            <strong>Persona de referencia del TPV:</strong> {{ $('Preparar Notif TPV NI').first().json.tpvPersona || '—' }}<br>\n            <strong>Email de referencia del TPV:</strong> {{ $('Preparar Notif TPV NI').first().json.tpvEmail || '—' }}\n          </td></tr>\n        </table>\n        <p style=\"margin:0;font-size:13px;color:#64748b;line-height:1.6;\">Equipo Yurest</p>\n      </td></tr>\n      <tr><td style=\"background:#f8fafc;border-radius:0 0 14px 14px;border-top:1.5px solid #e2e8f0;padding:14px 32px;font-size:11px;color:#94a3b8;\">© Yurest · Aviso automático</td></tr>\n    </table>\n  </td></tr>\n</table>\n</body>\n</html>",
        "options": {}
      },
