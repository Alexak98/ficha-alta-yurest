    {
      "parameters": {
        "jsCode": "const body = $input.first().json.body;\nconst p = body.proyecto;\n\nif (!p || !p.id) {\n  throw new Error('Falta el ID del proyecto para actualizar');\n}\n\nconst row = { id: p.id };\n\nconst fieldMap = {\n  cliente: 'cliente',\n  implementador: 'implementador',\n  tipo: 'tipo',\n  estado: 'estado',\n  fechaInicio: 'fecha_inicio',\n  fecha_inicio: 'fecha_inicio',\n  ultimaActividad: 'ultima_actividad',\n  ultima_actividad: 'ultima_actividad',\n  tpv: 'tpv',\n  motivoPausa: 'motivo_pausa',\n  motivo_pausa: 'motivo_pausa',\n  planAccion: 'plan_accion',\n  plan_accion: 'plan_accion',\n  asanaProjectId: 'asana_project_id',\n  asana_project_id: 'asana_project_id',\n  asanaProjectUrl: 'asana_project_url',\n  asana_project_url: 'asana_project_url',\n  anotaciones: 'anotaciones'\n};\n\nfor (const [from, to] of Object.entries(fieldMap)) {\n  if (p[from] !== undefined) row[to] = p[from];\n}\n\nif (p.contactos !== undefined) row.contactos = JSON.stringify(p.contactos);\nif (p.participantes !== undefined) row.participantes = p.participantes;\nif (p.adjuntos !== undefined) row.adjuntos = JSON.stringify(p.adjuntos);\nif (p.secciones !== undefined) row.secciones = JSON.stringify(p.secciones);\nif (p.ficha_id || p.fichaId) row.ficha_id = p.ficha_id || p.fichaId;\n\nreturn [{ json: row }];"
      },
