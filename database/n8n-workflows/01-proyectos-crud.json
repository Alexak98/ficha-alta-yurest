      "id": "wh-post",
      "name": "Webhook POST",
      "type": "n8n-nodes-base.webhook",
      "typeVersion": 2,
      "position": [240, 420],
      "webhookId": "proyectos-post"
    },
    {
      "parameters": {
        "jsCode": "const body = $input.first().json.body;\nconst p = body.proyecto;\n\nif (!p || !p.cliente || !p.implementador || !p.tipo) {\n  throw new Error('Faltan campos obligatorios: cliente, implementador, tipo');\n}\n\nconst row = {\n  cliente: p.cliente,\n  implementador: p.implementador,\n  tipo: p.tipo,\n  estado: p.estado || 'activo',\n  fecha_inicio: p.fechaInicio || p.fecha_inicio || new Date().toISOString().split('T')[0],\n  ultima_actividad: p.ultimaActividad || p.ultima_actividad || new Date().toISOString().split('T')[0],\n  tpv: p.tpv || '',\n  motivo_pausa: p.motivoPausa || p.motivo_pausa || '',\n  plan_accion: p.planAccion || p.plan_accion || '',\n  asana_project_id: p.asanaProjectId || p.asana_project_id || '',\n  anotaciones: p.anotaciones || '',\n  contactos: JSON.stringify(p.contactos || []),\n  participantes: p.participantes || [],\n  adjuntos: JSON.stringify(p.adjuntos || []),\n  secciones: JSON.stringify(p.secciones || [])\n};\n\nif (p.ficha_id || p.fichaId) row.ficha_id = p.ficha_id || p.fichaId;\nif (p.plantilla_id || p.plantillaId) row.plantilla_id = p.plantilla_id || p.plantillaId;\n\nreturn [{ json: row }];"
      },
      "id": "prepare-insert",
      "name": "Preparar INSERT",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
