      "id": "wh-grupos-action",
      "name": "Webhook Grupos Action",
      "type": "n8n-nodes-base.webhook",
      "typeVersion": 2,
      "position": [240, 600],
      "webhookId": "notif-integraciones-grupos-action"
    },
    {
      "parameters": {
        "jsCode": "// Router: convierte el body en un row preparado para INSERT/UPDATE/DELETE.\n// El frontend envía { action: 'create'|'update'|'delete', grupo: {...} }.\nconst b = $input.first().json.body || {};\nconst action = String(b.action || '').toLowerCase();\nconst g = b.grupo || {};\n\nif (!['create','update','delete'].includes(action)) {\n  throw new Error('action requerida: create | update | delete');\n}\n\nfunction buildRow(g) {\n  const row = {};\n  if (g.nombre        !== undefined) row.nombre        = String(g.nombre).trim();\n  if (g.destinatarios !== undefined) row.destinatarios = String(g.destinatarios).trim();\n  if (g.activo        !== undefined) row.activo        = !!g.activo;\n  if (g.orden         !== undefined) row.orden         = parseInt(g.orden, 10) || 0;\n  if (g.filtro_tpv       !== undefined) row.filtro_tpv       = JSON.stringify(Array.isArray(g.filtro_tpv) ? g.filtro_tpv : []);\n  if (g.filtro_secciones !== undefined) row.filtro_secciones = JSON.stringify(Array.isArray(g.filtro_secciones) ? g.filtro_secciones : []);\n  return row;\n}\n\nlet payload;\nif (action === 'create') {\n  if (!g.nombre || !g.destinatarios) throw new Error('Faltan nombre o destinatarios');\n  payload = buildRow(g);\n} else if (action === 'update') {\n  if (!g.id) throw new Error('Falta id para update');\n  payload = { id: g.id, ...buildRow(g) };\n} else if (action === 'delete') {\n  if (!g.id) throw new Error('Falta id para delete');\n  payload = { id: g.id, deleted_at: new Date().toISOString() };\n}\n\nreturn [{ json: { action, payload } }];"
      },
      "id": "prepare-grupo-action",
      "name": "Preparar acción Grupo",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [460, 600],
      "alwaysOutputData": true
    },
    {
      "parameters": {
