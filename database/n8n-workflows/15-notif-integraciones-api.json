    {
      "parameters": {
        "jsCode": "// Paginación: lee limit y offset de la query string y los sanea.\nconst q = ($input.first().json && $input.first().json.query) || {};\nconst limit = Math.min(Math.max(parseInt(q.limit, 10) || 50, 1), 500);\nconst offset = Math.max(parseInt(q.offset, 10) || 0, 0);\nreturn [{ json: { limit, offset } }];"
      },
      "id": "prep-hist-paging",
      "name": "Extraer paginación",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [360, 800],
      "alwaysOutputData": true
    },
    {
      "parameters": {
        "operation": "getAll",
        "tableId": "notif_integraciones_historial",
        "returnAll": false,
        "limit": "={{ $json.limit }}",
        "filterType": "string",
        "filterString": "=order=ejecutado_at.desc&offset={{ $json.offset }}",
        "options": {}
      },
      "id": "supa-get-historial",
      "name": "GET Historial Supabase",
      "type": "n8n-nodes-base.supabase",
      "typeVersion": 1,
      "position": [560, 800],
      "credentials": {
        "supabaseApi": {
          "id": "SUPABASE_CREDENTIAL_ID",
          "name": "Supabase Yurest"
        }
      },
      "alwaysOutputData": true
    },
    {
      "parameters": {
        "jsCode": "// Devuelve el historial parseando el JSONB `tareas`. Incluye metadatos\n// de paginación para que el frontend sepa si hay más filas disponibles.\nfunction parseJsonField(v, fb) {\n  if (v == null) return fb;\n  if (Array.isArray(v) || typeof v === 'object') return v;\n  if (typeof v === 'string') { try { return JSON.parse(v); } catch (_) { return fb; } }\n  return fb;\n}\nconst { limit, offset } = $('Extraer paginación').first().json;\nconst rows = $input.all().map(i => i.json).filter(r => r && r.id);\nfor (const r of rows) {\n  r.tareas = parseJsonField(r.tareas, []);\n}\n// has_more = true si devolvimos exactamente el límite — hay posiblemente\n// más filas. El frontend usa esto para decidir si mostrar \"cargar más\".\nreturn [{ json: {\n  historial: rows,\n  paging: { limit, offset, count: rows.length, has_more: rows.length >= limit }\n} }];"
      },
      "id": "format-historial",
      "name": "Formatear Historial",
      "type": "n8n-nodes-base.code",
