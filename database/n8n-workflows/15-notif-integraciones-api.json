    {
      "parameters": {
        "jsCode": "// Prepara el row a actualizar: sólo los campos mutables + id.\n// Usar autoMapInputData en el nodo Supabase garantiza que no se\n// inyecten columnas no mencionadas (evita la violación NOT NULL en\n// nombre/destinatarios que pasaba con defineBelow).\nreturn [{ json: { ...$('Preparar acción Grupo').first().json.payload } }];"
      },
      "id": "prep-update-row",
      "name": "Preparar row UPDATE",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [800, 600],
      "alwaysOutputData": true
    },
    {
      "parameters": {
        "method": "PATCH",
        "url": "=https://{{ $credentials.supabaseApi.host }}/rest/v1/notif_integraciones_grupos?id=eq.{{ $json.id }}",
        "authentication": "predefinedCredentialType",
        "nodeCredentialType": "supabaseApi",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            { "name": "Prefer",       "value": "return=representation" },
            { "name": "Content-Type", "value": "application/json" }
          ]
        },
        "sendBody": true,
        "bodyContentType": "json",
        "specifyBody": "json",
        "jsonBody": "={{ JSON.stringify({ nombre: $json.nombre, destinatarios: $json.destinatarios, activo: $json.activo, orden: $json.orden, filtro_tpv: $json.filtro_tpv, filtro_secciones: $json.filtro_secciones }) }}",
        "options": { "response": { "response": { "fullResponse": false } } }
      },
      "id": "http-update-grupo",
      "name": "UPDATE Grupo",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [1000, 600],
      "credentials": {
        "supabaseApi": {
          "id": "SUPABASE_CREDENTIAL_ID",
          "name": "Supabase Yurest"
        }
      },
      "alwaysOutputData": true,
      "continueOnFail": true
    },
    {
      "parameters": {
        "jsCode": "// Prepara el item para el DELETE físico: sólo necesitamos el id para\n// el filtro. El historial conserva grupo_nombre como texto, así que no\n// hace falta soft-delete.\nconst payload = $('Preparar acción Grupo').first().json.payload;\nreturn [{ json: { id: payload.id } }];"
      },
      "id": "prep-delete-row",
      "name": "Preparar row DELETE",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [800, 720],
      "alwaysOutputData": true
    },
    {
      "parameters": {
        "method": "DELETE",
        "url": "=https://{{ $credentials.supabaseApi.host }}/rest/v1/notif_integraciones_grupos?id=eq.{{ $json.id }}",
        "authentication": "predefinedCredentialType",
        "nodeCredentialType": "supabaseApi",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            { "name": "Prefer", "value": "return=representation" }
          ]
        },
        "options": { "response": { "response": { "fullResponse": false } } }
      },
      "id": "http-delete-grupo",
      "name": "DELETE Grupo",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [1000, 720],
      "credentials": {
        "supabaseApi": {
          "id": "SUPABASE_CREDENTIAL_ID",
          "name": "Supabase Yurest"
        }
      },
      "alwaysOutputData": true,
      "continueOnFail": true
    },
    {
      "parameters": {
        "jsCode": "// Verifica que la operación afectó alguna fila. Soporta 3 formatos de\n// entrada distintos según el nodo que acaba de ejecutarse:\n//  A) Supabase node (INSERT): item.json = { id, ...row }\n//  B) Supabase node con error + continueOnFail: item.json = { error: {...} }\n//  C) HTTP Request node (UPDATE/DELETE vía REST API): item.json = [{...row}, ...]\n//     o bien, en caso de error, item.json = { code, message, details }\nconst { action } = $('Preparar acción Grupo').first().json;\nconst input = $input.all();\nlet count = 0;\nconst errores = [];\nlet grupo = null;\n\nfor (const it of (input || [])) {\n  const j = (it && it.json) ? it.json : it;\n  if (!j) continue;\n\n  // Formato B: error Supabase wrap\n  if (j.error) {\n    errores.push(String(j.error.message || j.error.code || j.error));\n    continue;\n  }\n\n  // Formato C-error: body de PostgREST con code+message sin datos (400/409 etc.)\n  if (j.code && j.message && !j.id) {\n    errores.push(j.message + (j.details ? ' (' + j.details + ')' : ''));\n    continue;\n  }\n\n  // Formato C: array de filas devueltas por PostgREST\n  if (Array.isArray(j)) {\n    count += j.length;\n    if (!grupo && j.length > 0) grupo = j[0];\n    continue;\n  }\n\n  // Formato A: fila individual\n  if (j.id) {\n    count++;\n    if (!grupo) grupo = j;\n    continue;\n  }\n\n  // Compat legacy: {data: [...]}\n  if (Array.isArray(j.data)) { count += j.data.length; continue; }\n}\n\n// Si es delete y no hubo error ni count, pero llegamos aquí, asumimos\n// éxito (204 No Content sin body).\nif (action === 'delete' && count === 0 && errores.length === 0 && input.length > 0) {\n  count = 1;\n}\n\nreturn [{ json: {\n  success: count > 0,\n  action,\n  affected: count,\n  errores,\n  grupo\n}}];"
      },
      "id": "verify-grupo",
      "name": "Verificar resultado",
