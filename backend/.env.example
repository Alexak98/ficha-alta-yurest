APP_NAME=Yurest
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=es
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=es_ES
APP_TIMEZONE=Europe/Madrid

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# === Base de datos (Postgres) ===
DB_CONNECTION=pgsql
DB_HOST=pgsql
DB_PORT=5432
DB_DATABASE=yurest
DB_USERNAME=yurest
DB_PASSWORD=yurest

# En dev/prod (Forge) usaremos credenciales reales:
# DB_HOST=127.0.0.1
# DB_DATABASE=yurest_prod
# DB_USERNAME=...
# DB_PASSWORD=...

# === Sesión / Cache / Cola ===
SESSION_DRIVER=redis
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=s3
QUEUE_CONNECTION=redis
CACHE_STORE=redis

# === Redis ===
REDIS_CLIENT=phpredis
REDIS_HOST=redis
REDIS_PASSWORD=null
REDIS_PORT=6379

# === Mail ===
MAIL_MAILER=smtp
MAIL_HOST=mailpit
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="soporte@yurest.com"
MAIL_FROM_NAME="${APP_NAME}"

# === S3 / MinIO (adjuntos, exports, backups) ===
AWS_ACCESS_KEY_ID=sail
AWS_SECRET_ACCESS_KEY=password
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=yurest-local
AWS_ENDPOINT=http://minio:9000
AWS_USE_PATH_STYLE_ENDPOINT=true

# === Sanctum (auth) ===
SANCTUM_STATEFUL_DOMAINS=alexak98.github.io,localhost,localhost:8090,127.0.0.1,127.0.0.1:8090

# === Integraciones externas ===
# Asana
ASANA_PAT=
ASANA_PROJECT_ID=

# Zendesk
ZENDESK_SUBDOMAIN=
ZENDESK_EMAIL=
ZENDESK_TOKEN=

# OpenAI (resúmenes IA, churn técnico)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Google (Calendar, Drive)
GOOGLE_SERVICE_ACCOUNT_JSON=

# A3 (contabilidad)
A3_API_URL=
A3_API_KEY=

# === Sail / dev tools ===
SAIL_XDEBUG_MODE=develop,debug
SAIL_XDEBUG_CONFIG="client_host=host.docker.internal"

# === Backups (spatie/laravel-backup) ===
BACKUP_ARCHIVE_PASSWORD=
BACKUP_DESTINATION_DISK=s3
BACKUP_HEALTHCHECKS_URL=

# === Migración desde Supabase (one-shot) ===
# DSN del Postgres origen para `php artisan yurest:import-users`.
# Borra esta línea cuando termines el import — contiene credenciales sensibles.
# SUPABASE_DSN=postgres://postgres:PASSWORD@db.kyvzrqxicxirnroowriq.supabase.co:5432/postgres

# Password del admin local que crea DatabaseSeeder (solo dev/test).
SEED_ADMIN_PASSWORD=password
