APP_NAME=Yurest
APP_ENV=production
APP_KEY=                       # rellena con: php artisan key:generate
APP_DEBUG=false
APP_URL=https://api.tu-dominio.com

APP_LOCALE=es
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=es_ES
APP_TIMEZONE=Europe/Madrid

APP_MAINTENANCE_DRIVER=file
BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=info

# === Postgres dedicado en el servidor ===
DB_CONNECTION=pgsql
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=yurest_prod
DB_USERNAME=forge
DB_PASSWORD=                   # te lo da Forge al crear el sitio

# === Sesión / Cache / Cola ===
SESSION_DRIVER=redis
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=s3
QUEUE_CONNECTION=redis
CACHE_STORE=redis

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# === Mail (corporativo SMTP) ===
MAIL_MAILER=smtp
MAIL_HOST=                     # ej. smtp.hostinger.com
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=soporte@yurest.com
MAIL_FROM_NAME="${APP_NAME}"

# === S3 (Hetzner Object Storage para backups) ===
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=eu-central-1
AWS_BUCKET=yurest-backups
AWS_ENDPOINT=https://nbg1.your-objectstorage.com
AWS_USE_PATH_STYLE_ENDPOINT=true

# === Sanctum ===
# Si quieres modo SPA same-origin con cookies, listar dominios aquí (CSV).
# Por defecto usamos Bearer tokens cross-origin → no hace falta.
SANCTUM_STATEFUL_DOMAINS=

# === CORS — orígenes que pueden llamar a la API ===
# CSV. Sobrescribe el default de config/cors.php (que era solo
# alexak98.github.io). Añade aquí los frontends que tengan que llamar.
CORS_ALLOWED_ORIGINS=https://alexak98.github.io

# === Backups (spatie/laravel-backup) ===
BACKUP_DESTINATION_DISK=s3
BACKUP_HEALTHCHECKS_URL=       # https://hc-ping.com/XXX (crea en healthchecks.io)
BACKUP_ARCHIVE_PASSWORD=       # password del zip — guárdalo en tu gestor de contraseñas

# === Integraciones externas — completar cuando se activen ===
# ASANA_PAT=
# OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o-mini
# ZENDESK_SUBDOMAIN=
# ZENDESK_EMAIL=
# ZENDESK_TOKEN=
# GOOGLE_SERVICE_ACCOUNT_JSON=

# === Solo si se reactiva la migración de usuarios desde Supabase ===
# SUPABASE_DSN=
